# Dockerfile.sa — Supervision Agent (SA)
#
# Multi-stage build identical in structure to Dockerfile.rsa:
#   Stage 1 (builder): install Python dependencies into /install
#   Stage 2 (runtime): copy only the installed packages + source code
#
# The runtime image has no build tools (gcc, pip, etc.) — reduces
# attack surface and image size.
#
# The SA requires two additional dependencies beyond the base requirements.txt:
#   fastapi   — the web framework for the operator control surface
#   uvicorn   — the ASGI server that runs FastAPI
# These are added in the RUN command below alongside requirements.txt.
#
# Build command (run from mas-agent/ directory):
#   docker build -f Dockerfile.sa -t mas-sa:latest .
#
# Load into K3D (no registry needed):
#   k3d image import mas-sa:latest --cluster datacenter-lab

FROM python:3.11-slim AS builder

WORKDIR /build
COPY requirements.txt .

# Install base requirements plus SA-specific web server dependencies.
# fastapi[standard] includes uvicorn and httpx (needed for FastAPI's
# built-in test client, which we do not use here but is a harmless addition).
# We install uvicorn[standard] explicitly so the libuv event loop is available.
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt \
 && pip install --no-cache-dir --prefix=/install \
      "fastapi==0.111.0" \
      "uvicorn[standard]==0.29.0"

# ---- Runtime image ----
FROM python:3.11-slim

WORKDIR /app

# Copy installed packages from the builder stage
COPY --from=builder /install /usr/local

# Copy SA Python source package
COPY sa/ ./sa/

# Create a non-root user — uid 1001 matches MRA, PFA, and RSA convention
RUN useradd -r -u 1001 -g root sa-agent
USER sa-agent

CMD ["python3", "-m", "sa.main"]
